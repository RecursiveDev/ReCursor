---
import Default from '@astrojs/starlight/components/Head.astro';
interface Props {
  title?: string;
  description?: string;
}
---

<Default><slot /></Default>

<!-- Preconnect to font sources -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link 
  href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600;700&display=swap" 
  rel="stylesheet" 
/>

<!-- Favicon and theme color -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="theme-color" content="#0f1115" media="(prefers-color-scheme: dark)" />
<meta name="theme-color" content="#FDFCF8" media="(prefers-color-scheme: light)" />

<!-- Skip link for keyboard navigation -->
<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    padding: 0.75rem 1.25rem;
    background: var(--sl-color-accent, #3d4f6f);
    color: white;
    font-weight: 600;
    border-radius: 9999px;
    text-decoration: none;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    font-family: var(--sl-font);
  }
  
  .skip-link:focus {
    top: 1rem;
    outline: 2px solid white;
    outline-offset: 2px;
  }
</style>

<!-- Mermaid diagram support -->
<script>
  import mermaid from 'mermaid';

  function currentTheme() {
    const root = document.documentElement;
    const themeValue = root.dataset.theme ?? '';
    const isDark =
      themeValue === 'dark' ||
      root.classList.contains('dark') ||
      window.matchMedia('(prefers-color-scheme: dark)').matches;

    return isDark ? 'dark' : 'default';
  }

  function prepareDiagrams() {
    const diagrams = document.querySelectorAll<HTMLElement>(
      'pre code.language-mermaid, pre[data-language="mermaid"]',
    );

    for (const source of diagrams) {
      const container = source.closest('.expressive-code') ?? source.closest('pre');
      if (!container) {
        continue;
      }

      const diagram = document.createElement('div');
      diagram.className = 'mermaid';
      diagram.dataset.definition = source.textContent ?? '';
      diagram.textContent = diagram.dataset.definition;
      container.replaceWith(diagram);
    }
  }

  function resetRenderedDiagrams() {
    const diagrams = document.querySelectorAll<HTMLElement>('.mermaid[data-definition]');
    for (const diagram of diagrams) {
      diagram.removeAttribute('data-processed');
      diagram.textContent = diagram.dataset.definition ?? '';
    }
  }

  async function renderMermaid() {
    prepareDiagrams();
    resetRenderedDiagrams();

    mermaid.initialize({
      startOnLoad: false,
      securityLevel: 'loose',
      theme: currentTheme(),
    });

    await mermaid.run({ querySelector: '.mermaid' });
  }

  let observerAttached = false;

  function attachThemeObserver() {
    if (observerAttached) {
      return;
    }

    const observer = new MutationObserver(() => {
      void renderMermaid();
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class', 'data-theme'],
    });

    observerAttached = true;
  }

  document.addEventListener('astro:page-load', () => {
    attachThemeObserver();
    void renderMermaid();
  });
</script>

<!-- Smooth scroll for anchor links -->
<script is:inline>
  document.addEventListener('astro:page-load', () => {
    // Add smooth scroll behavior for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        const href = this.getAttribute('href');
        if (href && href !== '#') {
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            // Update URL without jump
            history.pushState(null, '', href);
          }
        }
      });
    });
  });
</script>
